# ─── Docker Compose Environment ─────────────────────────────────
# Copy this file to .env and fill in production values.

# JWT secret shared between backend and website — REQUIRED in production
JWT_SECRET=change-me-to-a-random-64-char-string

# API key for desktop app sync — REQUIRED in production
API_KEY=change-me-to-a-random-api-key

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Store phone number for WhatsApp integration
NEXT_PUBLIC_STORE_PHONE=212536690306
