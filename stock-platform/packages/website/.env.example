# Backend API URL — required for catalog/product data
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Store phone number for WhatsApp orders (no + prefix, e.g. 212536690306)
NEXT_PUBLIC_STORE_PHONE=212536690306

# JWT secret for admin authentication — REQUIRED in production
JWT_SECRET=change-me-to-a-random-secret-in-production
