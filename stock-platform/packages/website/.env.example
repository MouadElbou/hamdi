# ─── Website (Next.js) — its own backend ─────────────────────────────
# This is SEPARATE from the desktop-sync (Fastify) backend.

# Neon Postgres. Use the POOLED connection string for the app, and the
# DIRECT (non-pooled) one for migrations.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.REGION.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.REGION.aws.neon.tech/dbname?sslmode=require"

# Secret used to sign admin JWTs (must match what middleware.ts verifies).
# Generate a long random value, e.g. `openssl rand -base64 48`.
JWT_SECRET="change-me-to-a-long-random-string"

# Seed admin credentials (used once by `npm run db:seed`).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# ─── Cloudflare R2 (product images, S3-compatible) ───────────────────
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="hamdi-products"
# Public base URL of the bucket (r2.dev URL or a custom domain).
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ─── Frontend ────────────────────────────────────────────────────────
# Same-origin API. Leave as "/api" so the site talks to its own backend.
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_STORE_PHONE="212536690306"
