generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id              String           @id @default(uuid())
  code            String           @db.VarChar(50)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  originDesktopId String?
  version         Int              @default(1)
  deletedAt       DateTime?
  purchaseLots    PurchaseLot[]
  supplierCredits SupplierCredit[]

  @@index([code])
  @@index([deletedAt])
  @@map("suppliers")
}

model Boutique {
  id              String           @id @default(uuid())
  name            String           @db.VarChar(100)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  originDesktopId String?
  version         Int              @default(1)
  deletedAt       DateTime?
  expenses        Expense[]
  maintenanceJobs MaintenanceJob[]
  purchaseLots    PurchaseLot[]

  @@index([name])
  @@index([deletedAt])
  @@map("boutiques")
}

model Category {
  id              String          @id @default(uuid())
  name            String          @db.VarChar(200)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  originDesktopId String?
  version         Int             @default(1)
  deletedAt       DateTime?
  aliases         CategoryAlias[]
  purchaseLots    PurchaseLot[]
  subCategories   SubCategory[]

  @@index([name])
  @@index([deletedAt])
  @@map("categories")
}

model SubCategory {
  id              String        @id @default(uuid())
  name            String        @db.VarChar(200)
  categoryId      String
  version         Int           @default(1)
  originDesktopId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  category        Category      @relation(fields: [categoryId], references: [id])
  purchaseLots    PurchaseLot[]

  @@index([categoryId])
  @@index([name])
  @@index([deletedAt])
  @@map("sub_categories")
}

model CategoryAlias {
  id              String    @id @default(uuid())
  rawValue        String    @db.VarChar(200)
  categoryId      String
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?
  originDesktopId String?
  updatedAt       DateTime  @updatedAt
  version         Int       @default(1)
  category        Category  @relation(fields: [categoryId], references: [id])

  @@index([rawValue])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("category_aliases")
}

model Client {
  id              String      @id @default(uuid())
  name            String      @db.VarChar(200)
  phone           String?     @db.VarChar(50)
  version         Int         @default(1)
  originDesktopId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  saleOrders      SaleOrder[]
  customerOrders  CustomerOrder[]

  @@index([name])
  @@index([deletedAt])
  @@map("clients")
}

model PurchaseLot {
  id                String     @id
  refNumber         String     @db.VarChar(100)
  date              DateTime   @db.Date
  designation       String     @db.VarChar(500)
  initialQuantity   Int
  purchaseUnitCost  Int
  targetResalePrice Int?
  categoryId        String
  supplierId        String
  boutiqueId        String
  subCategoryId     String?
  sellingPrice      Int?
  version           Int          @default(1)
  originDesktopId   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  blockPrice        Int?
  barcode           String?      @db.VarChar(200)
  boutique          Boutique     @relation(fields: [boutiqueId], references: [id])
  category          Category     @relation(fields: [categoryId], references: [id])
  supplier          Supplier     @relation(fields: [supplierId], references: [id])
  subCategory       SubCategory? @relation(fields: [subCategoryId], references: [id])
  saleLines         SaleLine[]
  saleReturnLines   SaleReturnLine[]
  customerOrderLines CustomerOrderLine[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([boutiqueId])
  @@index([subCategoryId])
  @@index([date])
  @@index([barcode])
  @@index([deletedAt])
  @@map("purchase_lots")
}

model SaleOrder {
  id              String     @id
  refNumber       String     @db.VarChar(100)
  date            DateTime   @db.Date
  observation     String?
  version         Int        @default(1)
  originDesktopId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  clientId        String?
  lines           SaleLine[]
  returns         SaleReturn[]
  client          Client?          @relation(fields: [clientId], references: [id])
  customerCredits CustomerCredit[]

  @@index([clientId])
  @@index([date])
  @@index([deletedAt])
  @@map("sale_orders")
}

model SaleLine {
  id               String      @id
  sellingUnitPrice Int
  quantity         Int
  saleOrderId      String
  lotId            String
  version          Int         @default(1)
  originDesktopId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?
  lot              PurchaseLot      @relation(fields: [lotId], references: [id])
  saleOrder        SaleOrder        @relation(fields: [saleOrderId], references: [id])
  returnLines      SaleReturnLine[]

  @@index([saleOrderId])
  @@index([lotId])
  @@index([deletedAt])
  @@map("sale_lines")
}

model SaleReturn {
  id              String           @id
  refNumber       String           @db.VarChar(100)
  date            DateTime         @db.Date
  observation     String?
  saleOrderId     String
  version         Int              @default(1)
  originDesktopId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  saleOrder       SaleOrder        @relation(fields: [saleOrderId], references: [id])
  lines           SaleReturnLine[]

  @@index([saleOrderId])
  @@index([deletedAt])
  @@map("sale_returns")
}

model SaleReturnLine {
  id               String      @id
  sellingUnitPrice Int
  quantity         Int
  saleReturnId     String
  saleLineId       String
  lotId            String
  version          Int         @default(1)
  originDesktopId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?
  saleReturn       SaleReturn  @relation(fields: [saleReturnId], references: [id])
  saleLine         SaleLine    @relation(fields: [saleLineId], references: [id])
  lot              PurchaseLot @relation(fields: [lotId], references: [id])

  @@index([saleReturnId])
  @@index([saleLineId])
  @@index([lotId])
  @@index([deletedAt])
  @@map("sale_return_lines")
}

model CustomerOrder {
  id              String              @id
  refNumber       String              @db.VarChar(100)
  date            DateTime            @db.Date
  observation     String?
  clientId        String?
  status          String              @default("pending") @db.VarChar(20)
  version         Int                 @default(1)
  originDesktopId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  client          Client?             @relation(fields: [clientId], references: [id])
  lines           CustomerOrderLine[]

  @@index([clientId])
  @@index([date])
  @@index([status])
  @@index([deletedAt])
  @@map("customer_orders")
}

model CustomerOrderLine {
  id               String        @id
  customerOrderId  String
  lotId            String
  quantity         Int
  sellingUnitPrice Int
  version          Int           @default(1)
  originDesktopId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  customerOrder    CustomerOrder @relation(fields: [customerOrderId], references: [id])
  lot              PurchaseLot   @relation(fields: [lotId], references: [id])

  @@index([customerOrderId])
  @@index([lotId])
  @@index([deletedAt])
  @@map("customer_order_lines")
}

model MaintenanceJob {
  id              String    @id
  date            DateTime  @db.Date
  designation     String    @db.VarChar(500)
  price           Int
  boutiqueId      String
  version         Int       @default(1)
  originDesktopId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  boutique        Boutique  @relation(fields: [boutiqueId], references: [id])

  @@index([boutiqueId])
  @@index([date])
  @@index([deletedAt])
  @@map("maintenance_jobs")
}

model BatteryTariff {
  id                String    @id
  label             String    @db.VarChar(200)
  particuliersPrice Int?
  revPrice          Int?
  version           Int       @default(1)
  originDesktopId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([label])
  @@map("battery_tariffs")
}

model BatteryRepairJob {
  id              String    @id
  date            DateTime  @db.Date
  description     String    @db.VarChar(500)
  customerNote    String?
  amount          Int
  costAdjustment  Int       @default(0)
  version         Int       @default(1)
  originDesktopId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([date])
  @@index([deletedAt])
  @@map("battery_repair_jobs")
}

model Employee {
  id              String          @id
  name            String          @db.VarChar(200)
  monthlySalary   Int
  startDate       DateTime        @db.Date
  isActive        Boolean         @default(true)
  version         Int             @default(1)
  originDesktopId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  salaryPayments  SalaryPayment[]

  @@index([name])
  @@index([deletedAt])
  @@map("employees")
}

model SalaryPayment {
  id              String    @id
  date            DateTime  @db.Date
  amount          Int
  note            String?
  employeeId      String
  version         Int       @default(1)
  originDesktopId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([date])
  @@index([deletedAt])
  @@map("salary_payments")
}

model Expense {
  id              String    @id
  date            DateTime  @db.Date
  designation     String    @db.VarChar(200)
  amount          Int
  boutiqueId      String
  version         Int       @default(1)
  originDesktopId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  boutique        Boutique  @relation(fields: [boutiqueId], references: [id])

  @@index([boutiqueId])
  @@index([date])
  @@index([deletedAt])
  @@map("expenses")
}

model CustomerCredit {
  id              String                  @id
  date            DateTime                @db.Date
  // TODO(tech-debt): customerName is a denormalized string instead of a FK to Client.
  // Migration path: 1) add nullable clientId FK, 2) backfill by matching customerName→Client.name,
  // 3) resolve ambiguous/missing matches manually, 4) drop customerName column.
  customerName    String                  @db.VarChar(200)
  designation     String                  @db.VarChar(500)
  quantity        Int
  unitPrice       Int
  advancePaid     Int                     @default(0)
  dueDate         DateTime?               @db.Date
  saleOrderId     String?
  version         Int                     @default(1)
  originDesktopId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?
  payments        CustomerCreditPayment[]
  saleOrder       SaleOrder?              @relation(fields: [saleOrderId], references: [id])

  @@index([customerName])
  @@index([saleOrderId])
  @@index([deletedAt])
  @@map("customer_credits")
}

model CustomerCreditPayment {
  id               String         @id
  date             DateTime       @db.Date
  amount           Int
  customerCreditId String
  version          Int            @default(1)
  originDesktopId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  customerCredit   CustomerCredit @relation(fields: [customerCreditId], references: [id])

  @@index([customerCreditId])
  @@index([deletedAt])
  @@map("customer_credit_payments")
}

model SupplierCredit {
  id              String                  @id
  date            DateTime                @db.Date
  designation     String                  @db.VarChar(500)
  totalAmount     Int
  advancePaid     Int                     @default(0)
  supplierId      String
  version         Int                     @default(1)
  originDesktopId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?
  payments        SupplierCreditPayment[]
  supplier        Supplier                @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([deletedAt])
  @@map("supplier_credits")
}

model SupplierCreditPayment {
  id               String         @id
  date             DateTime       @db.Date
  amount           Int
  supplierCreditId String
  version          Int            @default(1)
  originDesktopId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  supplierCredit   SupplierCredit @relation(fields: [supplierCreditId], references: [id])

  @@index([supplierCreditId])
  @@index([deletedAt])
  @@map("supplier_credit_payments")
}

model BankMovement {
  id              String    @id
  date            DateTime  @db.Date
  description     String    @db.VarChar(500)
  amountIn        Int       @default(0)
  amountOut       Int       @default(0)
  version         Int       @default(1)
  originDesktopId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([date])
  @@index([deletedAt])
  @@map("bank_movements")
}

model MonthlySummary {
  id              String               @id
  year            Int
  month           Int
  version         Int                  @default(1)
  originDesktopId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  lines           MonthlySummaryLine[]

  @@index([year, month])
  @@index([deletedAt])
  @@map("monthly_summaries")
}

model MonthlySummaryLine {
  id               String         @id
  section          String         @db.VarChar(20)
  label            String         @db.VarChar(200)
  amount           Int
  isAutoComputed   Boolean        @default(false)
  monthlySummaryId String
  version          Int            @default(1)
  originDesktopId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  monthlySummary   MonthlySummary @relation(fields: [monthlySummaryId], references: [id])

  @@index([monthlySummaryId])
  @@index([deletedAt])
  @@map("monthly_summary_lines")
}

model ZakatSnapshot {
  id                 String         @id
  year               Int
  closingDate        DateTime       @db.Date
  closingStockValue  Int
  closingBankBalance Int
  closingCash        Int
  creditDeduction    Int
  version            Int            @default(1)
  originDesktopId    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  advances           ZakatAdvance[]

  @@index([year])
  @@index([deletedAt])
  @@map("zakat_snapshots")
}

model ZakatAdvance {
  id              String         @id
  date            DateTime       @db.Date
  amount          Int
  zakatSnapshotId String?
  version         Int            @default(1)
  originDesktopId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  note            String?
  year            Int?
  zakatSnapshot   ZakatSnapshot? @relation(fields: [zakatSnapshotId], references: [id])

  @@index([year])
  @@index([zakatSnapshotId])
  @@index([deletedAt])
  @@map("zakat_advances")
}

model SyncProcessedOperation {
  id          String   @id
  entityType  String   @db.VarChar(100)
  entityId    String
  operation   String   @db.VarChar(10)
  result      String   @db.VarChar(20)
  processedAt DateTime @default(now())

  @@index([entityType, entityId])
  @@map("sync_processed_operations")
}

model SyncAuditLog {
  id         String   @id @default(uuid())
  direction  String   @db.VarChar(10)
  entityType String   @db.VarChar(100)
  entityId   String
  operation  String   @db.VarChar(10)
  result     String   @db.VarChar(20)
  detail     String?
  desktopId  String
  occurredAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([desktopId])
  @@index([occurredAt])
  @@map("sync_audit_logs")
}

model ImportBatch {
  id           String          @id @default(uuid())
  fileName     String          @db.VarChar(500)
  startedAt    DateTime        @default(now())
  completedAt  DateTime?
  status       String          @db.VarChar(20)
  totalRows    Int             @default(0)
  importedRows Int             @default(0)
  anomalyCount Int             @default(0)
  anomalies    ImportAnomaly[]

  @@map("import_batches")
}

model ImportAnomaly {
  id             String      @id @default(uuid())
  entityType     String      @db.VarChar(100)
  entityId       String?
  anomalyType    String      @db.VarChar(50)
  rawValue       String
  canonicalValue String?
  description    String
  importBatchId  String
  createdAt      DateTime    @default(now())
  importBatch    ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId])
  @@index([anomalyType])
  @@map("import_anomalies")
}

model User {
  id                 String           @id @default(uuid())
  username           String           @unique @db.VarChar(50)
  passwordHash       String           @db.VarChar(255)
  displayName        String           @db.VarChar(100)
  role               UserRole         @default(employee)
  isActive           Boolean          @default(true)
  mustChangePassword Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  originDesktopId    String?
  version            Int              @default(1)
  permissions        UserPermission[]

  @@map("users")
}

model UserPermission {
  id        String   @id @default(uuid())
  pageKey   String   @db.VarChar(50)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pageKey])
  @@map("user_permissions")
}

enum UserRole {
  admin
  employee
}
