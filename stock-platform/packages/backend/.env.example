# PostgreSQL connection string — REQUIRED
# In Docker, the password comes from POSTGRES_PASSWORD (see docker-compose.yml / root .env).
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/stock_platform?schema=public"

# Server port (default: 3001)
PORT=3001

# Bind address (default: 127.0.0.1, use 0.0.0.0 for Docker)
HOST=127.0.0.1

# JWT secret for authentication — REQUIRED in production.
# Must be >= 32 chars and NOT this placeholder; the server refuses to start otherwise.
# Generate a real one with:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32

# API key for desktop sync authentication — REQUIRED in production.
# Must be >= 32 chars and NOT this placeholder. Generate with:  openssl rand -hex 32
API_KEY=REPLACE_WITH_openssl_rand_hex_32

# Comma-separated allowed CORS origins (default: permissive in dev)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (optional)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
