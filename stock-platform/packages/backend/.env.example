# PostgreSQL connection string — REQUIRED
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stock_platform?schema=public"

# Server port (default: 3001)
PORT=3001

# Bind address (default: 127.0.0.1, use 0.0.0.0 for Docker)
HOST=127.0.0.1

# JWT secret for authentication — REQUIRED in production (use a random 64+ char string)
JWT_SECRET=change-me-in-production

# API key for desktop sync authentication — REQUIRED in production
API_KEY=change-me-in-production

# Comma-separated allowed CORS origins (default: permissive in dev)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (optional)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
